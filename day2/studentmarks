#include <iostream>
#include <string>
using namespace std;
class student {
    public:
    string name;
    int marks;
    student(){name = "unknow";marks = 0;}
    student(string n,int m){name = n; marks =m;}
    void display(){
        cout<<name<<":"<<marks<<endl;}
};
int main(){
    student batch1[3]={
        student("arjun",85),
        student("priya",92),
        student("rahul",78)
    };
    cout<<"batch 1 (stack array):"<<endl;
    for (int i = 0;i<3;i++){
        batch1[i].display();
    }
    student*batch2 = new student[3]{
        student("sneha",88),
        student("vikram",76),
        student("ananya",95)
    };
    cout<<"\nbatch 2 (heap array):"<<endl;
    for (int i =0;i<3;i++){
        batch2[i].display();
    }
    delete[]batch2;
    return 0;
}
    