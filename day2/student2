#include <iostream>
#include <string>
using namespace std;
class student {
    public:
    string name;
    double marks;
    string email;
    student(){name = "unknow";marks = 0;email=e;}
    student(string n,double m,string e){name = n; marks =m; email =e;}
    void display(){
        cout<<name<<":"<<marks<<":"email<<endl;}
};
int main(){
    student batch1[3]={
        student("arjun",85.4,"abc@123"),
        student("priya",92.5,"abc@1234"),
        student("rahul",78.0,"XYZ@123")
    };
    cout<<"batch 1 (stack array):"<<endl;
    for (int i = 0;i<3;i++){
        batch1[i].display();
    }
    student*batch2 = new student[3]{
        student("sneha",88.8,"KAV@123"),
        student("vikram",76,"seeva2123"),
        student("ananya",95.5,"poo@123")
    };
    cout<<"\nbatch 2 (heap array):"<<endl;
    for (int i =0;i<3;i++){
        batch2[i].display();
    }
    delete[]batch2;
    return 0;
}
    