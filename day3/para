#include<iostream>
#include<string>
using namespace std;
class student{
    public;
    string namr;
    string  name;
    int age;
    double cgpa;
    student(string n,int a,double c){
        name=n;
        age=a;
        cgpa=c;
        cout<<"parameterized constructor called for"<<name<<"!"<<endl;
    }
    void display(){
        cout<<name<<"| age :"<<age<<"|  cgpa :"<<cgpa<<endl;
    }
};
int main(){
    student s1("arjun",20,8.5);                 
    student s2("priya",19,9.2);
    s1.display();                                               
    s2.display();
    return 0;
}


    