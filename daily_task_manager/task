<!DOCTYPE html>
<!-- Daily Task Manager: single-file app (HTML/CSS/JS). Uses localStorage for persistence. -->
<html lang="en">
<head>
	<meta charset="utf-8" />
	<meta name="viewport" content="width=device-width,initial-scale=1" />
	<title>Daily Task Manager</title>
	<style>
		:root{--bg:#f4f6f8;--card:#fff;--accent:#2b7cff;--muted:#6b7280}
		*{box-sizing:border-box;font-family:Inter,Segoe UI,Arial}
		body{margin:0;background:var(--bg);color:#111}
		.container{max-width:980px;margin:28px auto;padding:20px}
		header{display:flex;align-items:center;justify-content:space-between}
		h1{margin:0;font-size:20px}
		.card{background:var(--card);padding:18px;border-radius:10px;box-shadow:0 6px 18px rgba(20,20,40,0.06)}
		.auth{display:flex;gap:12px}
		.btn{background:var(--accent);color:#fff;padding:8px 12px;border-radius:8px;border:none;cursor:pointer}
		.btn.ghost{background:transparent;color:var(--accent);border:1px solid rgba(43,124,255,0.15)}
		.grid{display:grid;grid-template-columns:320px 1fr;gap:16px;margin-top:16px}
		form{display:flex;flex-direction:column;gap:8px}
		label{font-size:13px;color:var(--muted)}
		input,select,textarea{padding:10px;border-radius:8px;border:1px solid #e6e9ef}
		.task-list{display:flex;flex-direction:column;gap:8px;margin-top:12px}
		.task{display:flex;align-items:center;justify-content:space-between;padding:10px;border-radius:8px;border:1px solid #eef2f6}
		.task .left{display:flex;gap:12px;align-items:center}
		.priority{padding:5px 8px;border-radius:6px;font-size:12px}
		.priority.high{background:#ffe9e9;color:#b71c1c}
		.priority.medium{background:#fff4d9;color:#b35d00}
		.priority.low{background:#e9f6ff;color:#1b65b8}
		.small{font-size:12px;color:var(--muted)}
		.footer{margin-top:12px;display:flex;gap:8px}
		@media(max-width:800px){.grid{grid-template-columns:1fr}}
	</style>
</head>
<body>
	<div class="container">
		<header>
			<h1>Daily Task Manager</h1>
			<div class="auth card" id="auth-area">
				<!-- dynamic: login/register or user info -->
			</div>
		</header>

		<div class="grid">
			<div class="card">
				<div id="forms">
					<!-- registration and login forms inserted here -->
				</div>
			</div>

			<div class="card">
				<div id="app-area" style="display:none">
					<div style="display:flex;justify-content:space-between;align-items:center">
						<strong id="welcome"></strong>
						<div class="small">Tasks are saved locally</div>
					</div>

					<form id="task-form" style="margin-top:12px;display:flex;gap:8px;align-items:flex-start">
						<input id="title" placeholder="Task title" required />
						<select id="priority">
							<option value="high">High</option>
							<option value="medium" selected>Medium</option>
							<option value="low">Low</option>
						</select>
						<button class="btn" type="submit">Add</button>
					</form>

					<div class="task-list" id="task-list"></div>
				</div>
				<div id="logged-out" style="display:none">
					<p class="small">Please register or login to manage your tasks securely.</p>
				</div>
			</div>
		</div>
	</div>

	<script>
		// Minimal SQL-like schema (for reference)
		const SQL_SCHEMA = `-- Users table
CREATE TABLE users(id INTEGER PRIMARY KEY, username TEXT UNIQUE, password TEXT);
-- Tasks table
CREATE TABLE tasks(id INTEGER PRIMARY KEY, user_id INTEGER, title TEXT, priority TEXT, done INTEGER, created_at TEXT);`;

		// Simple auth + task manager using localStorage
		const STORAGE_KEY = 'dtm_v1';
		function loadStore(){return JSON.parse(localStorage.getItem(STORAGE_KEY)||'{}')}
		function saveStore(s){localStorage.setItem(STORAGE_KEY,JSON.stringify(s))}
		let store = loadStore(); if(!store.users) store={users:[],tasks:[] , session:null};

		// UI helpers
		const authArea = document.getElementById('auth-area');
		const forms = document.getElementById('forms');
		const appArea = document.getElementById('app-area');
		const loggedOut = document.getElementById('logged-out');
		const welcome = document.getElementById('welcome');
		const taskList = document.getElementById('task-list');

		function renderAuth(){
			authArea.innerHTML='';
			const s = store.session;
			if(s){
				const span = document.createElement('div'); span.className='small'; span.textContent = s.username;
				const btn = document.createElement('button'); btn.className='btn ghost'; btn.textContent='Logout'; btn.onclick=logout;
				authArea.appendChild(span); authArea.appendChild(btn);
			} else {
				const reg = document.createElement('button'); reg.className='btn'; reg.textContent='Register'; reg.onclick=showRegister;
				const ln = document.createElement('button'); ln.className='btn ghost'; ln.textContent='Login'; ln.onclick=showLogin;
				authArea.appendChild(reg); authArea.appendChild(ln);
			}
		}

		function showRegister(){
			forms.innerHTML = `
				<h3>Create account</h3>
				<form id="register">
					<label>Username</label>
					<input id="r-user" required />
					<label>Password</label>
					<input id="r-pass" type="password" required />
					<div class="footer"><button class="btn" type="submit">Register</button></div>
				</form>`;
			document.getElementById('register').onsubmit = e=>{e.preventDefault(); register();};
		}

		function showLogin(){
			forms.innerHTML = `
				<h3>Login</h3>
				<form id="login">
					<label>Username</label>
					<input id="l-user" required />
					<label>Password</label>
					<input id="l-pass" type="password" required />
					<div class="footer"><button class="btn" type="submit">Login</button></div>
				</form>`;
			document.getElementById('login').onsubmit = e=>{e.preventDefault(); login();};
		}

		function register(){
			const u = document.getElementById('r-user').value.trim();
			const p = document.getElementById('r-pass').value;
			if(!u||!p) return alert('Enter values');
			if(store.users.find(x=>x.username===u)) return alert('Username exists');
			const id = Date.now();
			store.users.push({id,username:u,password:btoa(p)});
			saveStore(store);
			alert('Registered. Please login');
			showLogin();
		}

		function login(){
			const u = document.getElementById('l-user').value.trim();
			const p = document.getElementById('l-pass').value;
			const user = store.users.find(x=>x.username===u && x.password===btoa(p));
			if(!user) return alert('Invalid');
			store.session = {id:user.id,username:user.username}; saveStore(store);
			initApp();
		}

		function logout(){ delete store.session; saveStore(store); initApp(); }

		function initApp(){ store = loadStore(); if(!store.users) store={users:[],tasks:[],session:null}; renderAuth();
			if(store.session){ forms.innerHTML=''; appArea.style.display='block'; loggedOut.style.display='none'; welcome.textContent=`Hello, ${store.session.username}`; renderTasks();
			} else { forms.innerHTML=''; appArea.style.display='none'; loggedOut.style.display='block'; }
		}

		// Tasks
		const taskForm = document.getElementById('task-form');
		taskForm.onsubmit = e=>{e.preventDefault(); addTask();};

		function addTask(){
			const t = document.getElementById('title').value.trim(); const p = document.getElementById('priority').value;
			if(!t) return; const id = Date.now();
			store.tasks.push({id,user_id:store.session.id,title:t,priority:p,done:0,created_at:new Date().toISOString()});
			saveStore(store); document.getElementById('title').value=''; renderTasks();
		}

		function renderTasks(){ taskList.innerHTML=''; const tasks = store.tasks.filter(x=>x.user_id===store.session.id).sort((a,b)=>b.created_at.localeCompare(a.created_at));
			if(tasks.length===0) taskList.innerHTML='<div class="small">No tasks yet</div>';
			tasks.forEach(t=>{ const el=document.createElement('div'); el.className='task';
				el.innerHTML = `<div class="left"><input type=checkbox ${t.done?'checked':''} data-id="${t.id}" />
					<div><div style="font-weight:600">${escapeHtml(t.title)}</div><div class="small">${new Date(t.created_at).toLocaleString()}</div></div></div>
					<div style="display:flex;gap:8px;align-items:center"><div class="priority ${t.priority}">${t.priority}</div><button class="btn ghost" data-del="${t.id}">Del</button></div>`;
				taskList.appendChild(el);
			});
			// handlers
			taskList.querySelectorAll('[data-id]').forEach(cb=>cb.onchange = e=>{ toggleDone(Number(cb.dataset.id),cb.checked); });
			taskList.querySelectorAll('[data-del]').forEach(b=>b.onclick = ()=>{ deleteTask(Number(b.dataset.del)); });
		}

		function toggleDone(id,checked){ const t = store.tasks.find(x=>x.id===id); if(!t) return; t.done = checked?1:0; saveStore(store); renderTasks(); }
		function deleteTask(id){ store.tasks = store.tasks.filter(x=>x.id!==id); saveStore(store); renderTasks(); }

		function escapeHtml(s){ return s.replace(/[&<>"']/g, c=>({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":"&#39;"}[c])); }

		// init
		initApp();
	</script>
</body>
</html>
